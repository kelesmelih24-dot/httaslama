# Supabase (Proje Ayarları > API sayfasından alınır)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Telegram (BotFather'dan alınır)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Admin girişi (istediginiz zaman degistirin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123

# Oturum imzalama anahtari - rastgele uzun bir metin girin (deployda mutlaka degistirin)
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string

# Sitemap/robots.txt icin - gercek alan adiniz (deploy sonrasi ekleyin)
NEXT_PUBLIC_SITE_URL=https://www.htmakinataslama.com

# AI destekli sohbet botu (Groq / Llama 3.3 70B) - https://console.groq.com adresinden alinir
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Admin paneli anlik bildirimleri (Web Push) icin VAPID anahtarlari
# Bu anahtarlari Claude ile birlikte olusturduk, asagidaki degerleri
# oldugu gibi kullanabilirsiniz (private key'i kimseyle paylasmayin)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:info@htmakinataslama.com
